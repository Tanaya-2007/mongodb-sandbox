# Port to run the server on
PORT=5000

# The master MongoDB Atlas connection string (without a database name or with a trailing slash).
# Used to generate the provisioned connection strings.
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/
MONGODB_ATLAS_URI=mongodb+srv://admin:password@cluster0.example.mongodb.net/

# The connection string for the management database where device-to-sandbox mappings are stored.
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/sandbox_management?retryWrites=true&w=majority
MANAGEMENT_DB_URI=mongodb+srv://admin:password@cluster0.example.mongodb.net/sandbox_management?retryWrites=true&w=majority
